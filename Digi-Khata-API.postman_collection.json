  "item": [
    {
      "name": "Inventory Management",
      "item": [
        {
          "name": "List All Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventory?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "inventory"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "q",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "active",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create New Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop\",\n  \"category\": \"Electronics\",\n  \"description\": \"High-performance laptop\",\n  \"currentStock\": 20,\n  \"reorderLevel\": 5,\n  \"unitOfMeasure\": \"piece\",\n  \"purchasePrice\": 600,\n  \"sellingPrice\": 900,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/inventory",
              "host": ["{{base_url}}"],
              "path": ["api", "inventory"]
            }
          }
        },
